# ============================================================
# AI Image Upscaler - Backend Environment Variables
# Copy this file to .env.local and fill in your real values
# ============================================================

# ModelsLab API Key (for Real-ESRGAN free upscaling)
# Get it at: https://modelslab.com → Dashboard → API Keys
MODELSLAB_API_KEY=your_modelslab_api_key_here

# Vercel Blob Storage Token (for temporary image uploads)
# Get it at: https://vercel.com/dashboard → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# OpenRouter API Key (for Pro AI models: Gemini, Riverflow)
# Get it at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxx

# ImageRouter API Key (free fallback upscaling)
# Get it at: https://imagerouter.io
IMAGEROUTER_API_KEY=your_imagerouter_key_here
